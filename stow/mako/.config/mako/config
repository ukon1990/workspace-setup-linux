# AUTOGENERATED BY theme manager (~/.config/themes/bin/theme).
# Do not edit by hand. Run `theme set <name>` to change themes.
# theme: paper-light (Paper Light)

font=Noto Sans 11
sort=-time
layer=overlay
anchor=top-right
default-timeout=5000
ignore-timeout=0
max-visible=5

background-color=#fbf6ecf0
text-color=#2d261cff
border-color=#a85a18ff
progress-color=over #f2d5acf0

border-size=2
border-radius=12
padding=12
margin=12
outer-margin=12
width=360
height=110

icons=1
max-icon-size=32
icon-path=/usr/share/icons/Papirus-Light
markup=1
actions=1
format=<b>%s</b>\n%b

[urgency=low]
background-color=#f5efe4e8
border-color=#b7a98dcc
text-color=#5a4f3dff
default-timeout=3000

[urgency=normal]
background-color=#fbf6ecf0
border-color=#a85a18ff
text-color=#2d261cff
default-timeout=5000

[urgency=high]
background-color=#ebe3d2f5
border-color=#a85a18ff
text-color=#2d1a08ff
default-timeout=0
