#!/usr/bin/env python3
"""Unified theme manager for Hyprland, Waybar, and Mako.

Reads a palette definition from ``~/.config/themes/palettes/<name>.json``
and regenerates the color files for each supported tool, then reloads
the running services so the change is visible immediately.
"""

from __future__ import annotations

import argparse
import json
import os
import shutil
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path


CONFIG_DIR = Path.home() / ".config"
THEME_DIR = CONFIG_DIR / "themes"
PALETTE_DIR = THEME_DIR / "palettes"
STATE_DIR = THEME_DIR / "state"
STATE_FILE = STATE_DIR / "current"

HYPR_THEME_FILE = CONFIG_DIR / "hypr" / "theme.conf"
HYPRLOCK_COLORS_FILE = CONFIG_DIR / "hypr" / "hyprlock-colors.conf"
WAYBAR_COLORS_FILE = CONFIG_DIR / "waybar" / "colors.css"
MAKO_CONFIG_FILE = CONFIG_DIR / "mako" / "config"

DEFAULT_THEME = "amber-dark"


# ---------------------------------------------------------------------------
# Color helpers
# ---------------------------------------------------------------------------


def hex_to_rgb(color: str) -> tuple[int, int, int]:
    color = color.lstrip("#")
    if len(color) != 6:
        raise ValueError(f"Expected 6 digit hex color, got {color!r}")
    return int(color[0:2], 16), int(color[2:4], 16), int(color[4:6], 16)


def rgba_css(color: str, alpha: float) -> str:
    r, g, b = hex_to_rgb(color)
    alpha = max(0.0, min(1.0, alpha))
    return f"rgba({r}, {g}, {b}, {alpha:.2f})"


def hypr_rgba(color: str, alpha: float = 1.0) -> str:
    """Return a color in Hyprland's ``rgba(RRGGBBAA)`` format."""
    r, g, b = hex_to_rgb(color)
    alpha_byte = max(0, min(255, round(alpha * 255)))
    return f"rgba({r:02x}{g:02x}{b:02x}{alpha_byte:02x})"


def mako_rgba(color: str, alpha: float = 1.0) -> str:
    """Return a color in Mako's ``#RRGGBBAA`` format."""
    r, g, b = hex_to_rgb(color)
    alpha_byte = max(0, min(255, round(alpha * 255)))
    return f"#{r:02x}{g:02x}{b:02x}{alpha_byte:02x}"


# ---------------------------------------------------------------------------
# Palette loading
# ---------------------------------------------------------------------------


@dataclass
class Palette:
    name: str
    display_name: str
    mode: str
    icon: str
    colors: dict[str, str]

    @property
    def is_dark(self) -> bool:
        return self.mode == "dark"


def palette_path(name: str) -> Path:
    return PALETTE_DIR / f"{name}.json"


def load_palette(name: str) -> Palette:
    path = palette_path(name)
    if not path.exists():
        raise SystemExit(f"Theme not found: {name} ({path})")
    data = json.loads(path.read_text())
    return Palette(
        name=data["name"],
        display_name=data.get("display_name", data["name"]),
        mode=data.get("mode", "dark"),
        icon=data.get("icon", ""),
        colors=data["colors"],
    )


def list_palettes() -> list[Palette]:
    palettes = []
    for path in sorted(PALETTE_DIR.glob("*.json")):
        try:
            palettes.append(load_palette(path.stem))
        except Exception as exc:
            print(f"warning: skipping {path.name}: {exc}", file=sys.stderr)
    return palettes


def current_theme_name() -> str:
    if STATE_FILE.exists():
        name = STATE_FILE.read_text().strip()
        if name and palette_path(name).exists():
            return name
    return DEFAULT_THEME


def save_current_theme(name: str) -> None:
    STATE_DIR.mkdir(parents=True, exist_ok=True)
    STATE_FILE.write_text(name + "\n")


# ---------------------------------------------------------------------------
# File generators
# ---------------------------------------------------------------------------


HYPR_HEADER = (
    "# #######################################################################\n"
    "# AUTOGENERATED BY theme manager (~/.config/themes/bin/theme).\n"
    "# Do not edit by hand. Run `theme set <name>` to change themes.\n"
    "# #######################################################################\n"
)


def render_hypr(palette: Palette) -> str:
    c = palette.colors
    lines = [HYPR_HEADER, f"# theme: {palette.name} ({palette.display_name})\n\n"]

    def var(name: str, value: str) -> None:
        lines.append(f"${name} = {value}\n")

    var("theme_active_border", hypr_rgba(c["hypr_active_border"], 1.0))
    var("theme_inactive_border", hypr_rgba(c["hypr_inactive_border"], 0.80))
    var("theme_shadow", hypr_rgba(c["shadow"], 0.93))
    var("theme_groupbar_text_active", hypr_rgba(c["groupbar_text_active"], 1.0))
    var("theme_groupbar_text_inactive", hypr_rgba(c["groupbar_text_inactive"], 0.87))
    var("theme_groupbar_active", hypr_rgba(c["groupbar_active"], 0.93))
    var("theme_groupbar_inactive", hypr_rgba(c["groupbar_inactive"], 0.93))
    var("theme_groupbar_locked_active", hypr_rgba(c["groupbar_locked_active"], 0.93))
    var("theme_groupbar_locked_inactive", hypr_rgba(c["groupbar_locked_inactive"], 0.93))
    return "".join(lines)


HYPRLOCK_HEADER = (
    "# #######################################################################\n"
    "# AUTOGENERATED BY theme manager (~/.config/themes/bin/theme).\n"
    "# Do not edit by hand. Run `theme set <name>` to change themes.\n"
    "# Consumed by ~/.config/hypr/hyprlock.conf via `source = ...`.\n"
    "# #######################################################################\n"
)


def render_hyprlock(palette: Palette) -> str:
    c = palette.colors
    fail = "#dc322f" if palette.is_dark else "#b91c1c"
    lines = [HYPRLOCK_HEADER, f"# theme: {palette.name} ({palette.display_name})\n\n"]

    def var(name: str, value: str) -> None:
        lines.append(f"${name} = {value}\n")

    var("lock_text", hypr_rgba(c["text"], 1.0))
    var("lock_text_muted", hypr_rgba(c["text_muted"], 1.0))
    var("lock_surface", hypr_rgba(c["surface"], 0.88))
    var("lock_outline", hypr_rgba(c["outline"], 0.80))
    var("lock_primary", hypr_rgba(c["primary"], 1.0))
    var("lock_accent", hypr_rgba(c.get("accent_container", c["primary"]), 1.0))
    var("lock_fail", hypr_rgba(fail, 1.0))
    return "".join(lines)


WAYBAR_HEADER = (
    "/*\n"
    " * AUTOGENERATED BY theme manager (~/.config/themes/bin/theme).\n"
    " * Do not edit by hand. Run `theme set <name>` to change themes.\n"
    " */\n"
)


def render_waybar(palette: Palette) -> str:
    c = palette.colors
    lines = [WAYBAR_HEADER, f"/* theme: {palette.name} ({palette.display_name}) */\n\n"]

    def define(name: str, value: str) -> None:
        lines.append(f"@define-color {name} {value};\n")

    define("bg", c["bg"])
    define("surface", rgba_css(c["surface"], 0.96))
    define("surface-high", c["surface_high"])
    define("surface-higher", c["surface_higher"])
    define("outline", c["outline"])
    define("outline-soft", rgba_css(c["outline"], 0.55))
    define("outline-strong", rgba_css(c["outline"], 0.90))
    define("text", c["text"])
    define("text-muted", c["text_muted"])
    define("text-faint", rgba_css(c["text_muted"], 0.45))
    define("text-muted-soft", rgba_css(c["text_muted"], 0.68))
    define("primary", c["primary"])
    define("primary-container", c["primary_container"])
    define("primary-border", rgba_css(c["primary"], 0.45))
    define("primary-border-strong", rgba_css(c["primary"], 0.72))
    define("on-primary", c["on_primary"])
    define("accent-container", rgba_css(c["accent_container"], 0.92))
    return "".join(lines)


MAKO_HEADER = (
    "# AUTOGENERATED BY theme manager (~/.config/themes/bin/theme).\n"
    "# Do not edit by hand. Run `theme set <name>` to change themes.\n"
)


def render_mako(palette: Palette) -> str:
    c = palette.colors
    icon_path = "/usr/share/icons/Papirus-Dark" if palette.is_dark else "/usr/share/icons/Papirus-Light"

    normal_bg = mako_rgba(c["surface"], 0.94)
    low_bg = mako_rgba(c["bg"], 0.91)
    high_bg = mako_rgba(c["surface_high"], 0.96)

    return f"""{MAKO_HEADER}# theme: {palette.name} ({palette.display_name})

font=Noto Sans 11
sort=-time
layer=overlay
anchor=top-right
default-timeout=5000
ignore-timeout=0
max-visible=5

background-color={normal_bg}
text-color={mako_rgba(c["text"], 1.0)}
border-color={mako_rgba(c["primary"], 1.0)}
progress-color=over {mako_rgba(c["primary_container"], 0.94)}

border-size=2
border-radius=12
padding=12
margin=12
outer-margin=12
width=360
height=110

icons=1
max-icon-size=32
icon-path={icon_path}
markup=1
actions=1
format=<b>%s</b>\\n%b

[urgency=low]
background-color={low_bg}
border-color={mako_rgba(c["outline"], 0.80)}
text-color={mako_rgba(c["text_muted"], 1.0)}
default-timeout=3000

[urgency=normal]
background-color={normal_bg}
border-color={mako_rgba(c["primary"], 1.0)}
text-color={mako_rgba(c["text"], 1.0)}
default-timeout=5000

[urgency=high]
background-color={high_bg}
border-color={mako_rgba(c["primary"], 1.0)}
text-color={mako_rgba(c["on_primary"], 1.0)}
default-timeout=0
"""


# ---------------------------------------------------------------------------
# Writer + reloader
# ---------------------------------------------------------------------------


def write_file(path: Path, contents: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_suffix(path.suffix + ".tmp")
    tmp.write_text(contents)
    tmp.replace(path)


def run(cmd: list[str]) -> tuple[bool, str]:
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=False, timeout=10)
    except FileNotFoundError:
        return False, f"not installed: {cmd[0]}"
    except subprocess.TimeoutExpired:
        return False, f"timeout: {' '.join(cmd)}"
    ok = result.returncode == 0
    output = (result.stdout or result.stderr).strip()
    return ok, output


def reload_services(quiet: bool = False) -> None:
    results = []
    if shutil.which("hyprctl"):
        ok, msg = run(["hyprctl", "reload"])
        results.append(("hyprland", ok, msg))
    if shutil.which("makoctl"):
        ok, msg = run(["makoctl", "reload"])
        results.append(("mako", ok, msg))
    if shutil.which("pkill"):
        ok, msg = run(["pkill", "-SIGUSR2", "waybar"])
        results.append(("waybar", ok, msg))

    if not quiet:
        for name, ok, msg in results:
            status = "ok" if ok else "FAIL"
            detail = f" ({msg})" if msg and not ok else ""
            print(f"  reload {name}: {status}{detail}")


def apply_system_appearance(palette: Palette, quiet: bool = False) -> None:
    """Tell the rest of the system whether we are in dark or light mode.

    Uses the freedesktop/GNOME ``color-scheme`` setting, which is picked up
    by GTK 4, the XDG desktop portal, and many Electron/Chromium apps.
    """
    results = []
    if shutil.which("gsettings"):
        scheme = "prefer-dark" if palette.is_dark else "prefer-light"
        ok, msg = run(["gsettings", "set", "org.gnome.desktop.interface", "color-scheme", scheme])
        results.append(("color-scheme", ok, msg))
        # Legacy key some apps still read:
        ok2, msg2 = run(["gsettings", "set", "org.gnome.desktop.interface", "gtk-application-prefer-dark-theme", "true" if palette.is_dark else "false"])
        results.append(("gtk-prefer-dark", ok2, msg2))

    if not quiet:
        for name, ok, msg in results:
            status = "ok" if ok else "FAIL"
            detail = f" ({msg})" if msg and not ok else ""
            print(f"  system {name}: {status}{detail}")


# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------


def apply_theme(name: str, reload: bool = True, quiet: bool = False) -> None:
    palette = load_palette(name)
    write_file(HYPR_THEME_FILE, render_hypr(palette))
    write_file(HYPRLOCK_COLORS_FILE, render_hyprlock(palette))
    write_file(WAYBAR_COLORS_FILE, render_waybar(palette))
    write_file(MAKO_CONFIG_FILE, render_mako(palette))
    save_current_theme(palette.name)
    if not quiet:
        print(f"Theme set: {palette.display_name} ({palette.name})")
        print(f"  hypr:     {HYPR_THEME_FILE}")
        print(f"  hyprlock: {HYPRLOCK_COLORS_FILE}")
        print(f"  waybar:   {WAYBAR_COLORS_FILE}")
        print(f"  mako:     {MAKO_CONFIG_FILE}")
    if reload:
        reload_services(quiet=quiet)
        apply_system_appearance(palette, quiet=quiet)


def cmd_set(args: argparse.Namespace) -> int:
    apply_theme(args.name, reload=not args.no_reload, quiet=args.quiet)
    return 0


def cmd_list(_: argparse.Namespace) -> int:
    current = current_theme_name()
    for p in list_palettes():
        marker = "*" if p.name == current else " "
        print(f"{marker} {p.name:<20} {p.display_name} ({p.mode})")
    return 0


def cmd_current(_: argparse.Namespace) -> int:
    print(current_theme_name())
    return 0


def cmd_cycle(args: argparse.Namespace) -> int:
    palettes = list_palettes()
    if not palettes:
        raise SystemExit("No themes available")
    names = [p.name for p in palettes]
    current = current_theme_name()
    idx = names.index(current) if current in names else 0
    step = -1 if args.backward else 1
    nxt = names[(idx + step) % len(names)]
    apply_theme(nxt, reload=True, quiet=args.quiet)
    return 0


def cmd_widget(_: argparse.Namespace) -> int:
    """Emit Waybar JSON for the theme switcher module."""
    palettes = list_palettes()
    current = current_theme_name()
    try:
        palette = load_palette(current)
    except SystemExit:
        palette = palettes[0] if palettes else None

    if palette is None:
        print(json.dumps({"text": " --", "tooltip": "No themes available", "class": "theme muted"}))
        return 0

    icon = palette.icon or ""
    text = f"{icon} {palette.display_name}".strip()
    names = [p.display_name for p in palettes]
    tooltip_lines = [
        f"Theme: {palette.display_name} ({palette.mode})",
        "",
        "Left click  : open picker (dropdown)",
        "Right click : next theme",
        "Middle click: previous theme",
        "Scroll      : cycle themes",
        "",
        "Available:",
    ]
    for p in palettes:
        marker = "*" if p.name == palette.name else " "
        tooltip_lines.append(f"{marker} {p.display_name} ({p.mode})")
    tooltip = "\n".join(tooltip_lines)
    css_class = f"theme theme-{palette.mode} theme-{palette.name}"
    print(json.dumps({"text": text, "tooltip": tooltip, "class": css_class, "alt": palette.name}))
    return 0


def _find_picker() -> list[str] | None:
    """Return a dmenu-style command positioned like a dropdown near the top-right."""
    for cmd in ("wofi", "fuzzel", "rofi", "bemenu"):
        if shutil.which(cmd):
            if cmd == "wofi":
                return [
                    "wofi",
                    "--dmenu",
                    "--prompt",
                    "Theme",
                    "--location",
                    "top_right",
                    "--width",
                    "260",
                    "--height",
                    "320",
                    "--lines",
                    "8",
                ]
            if cmd == "fuzzel":
                return [
                    "fuzzel",
                    "--dmenu",
                    "--prompt",
                    "Theme: ",
                    "--anchor",
                    "top-right",
                    "--width",
                    "24",
                    "--lines",
                    "8",
                ]
            if cmd == "rofi":
                return [
                    "rofi",
                    "-dmenu",
                    "-p",
                    "Theme",
                    "-theme-str",
                    "window { location: northeast; anchor: northeast; x-offset: -12px; y-offset: 52px; width: 260px; }",
                ]
            if cmd == "bemenu":
                return ["bemenu", "-p", "Theme"]
    return None


def cmd_picker(args: argparse.Namespace) -> int:
    palettes = list_palettes()
    if not palettes:
        raise SystemExit("No themes available")
    picker = _find_picker()
    entries = [f"{p.display_name}\t{p.name}" for p in palettes]
    stdin_text = "\n".join(entries)
    if not picker:
        # Fallback: just cycle forward
        return cmd_cycle(argparse.Namespace(backward=False, quiet=args.quiet))
    try:
        proc = subprocess.run(picker, input=stdin_text, capture_output=True, text=True, check=False)
    except FileNotFoundError:
        return cmd_cycle(argparse.Namespace(backward=False, quiet=args.quiet))
    choice = proc.stdout.strip()
    if not choice:
        return 0
    # accept either "Display Name\tinternal" or plain display name or plain internal
    name = None
    if "\t" in choice:
        name = choice.split("\t", 1)[1].strip()
    else:
        for p in palettes:
            if choice in (p.name, p.display_name):
                name = p.name
                break
    if not name:
        print(f"Unknown selection: {choice!r}", file=sys.stderr)
        return 1
    apply_theme(name, reload=True, quiet=args.quiet)
    return 0


def cmd_apply(args: argparse.Namespace) -> int:
    """Regenerate files for the currently saved theme without changing it."""
    apply_theme(current_theme_name(), reload=not args.no_reload, quiet=args.quiet)
    return 0


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(prog="theme", description="Unified theme manager")
    sub = parser.add_subparsers(dest="command", required=True)

    p_set = sub.add_parser("set", help="Apply a named theme")
    p_set.add_argument("name", help="Theme name, e.g. amber-dark")
    p_set.add_argument("--no-reload", action="store_true", help="Do not reload services")
    p_set.add_argument("-q", "--quiet", action="store_true")
    p_set.set_defaults(func=cmd_set)

    p_list = sub.add_parser("list", help="List available themes")
    p_list.set_defaults(func=cmd_list)

    p_current = sub.add_parser("current", help="Print the current theme name")
    p_current.set_defaults(func=cmd_current)

    p_cycle = sub.add_parser("cycle", help="Switch to the next/previous theme")
    p_cycle.add_argument("--backward", action="store_true", help="Go to previous theme")
    p_cycle.add_argument("-q", "--quiet", action="store_true")
    p_cycle.set_defaults(func=cmd_cycle)

    p_widget = sub.add_parser("widget", help="Emit Waybar JSON for the theme module")
    p_widget.set_defaults(func=cmd_widget)

    p_picker = sub.add_parser("picker", help="Open a dmenu-style theme picker")
    p_picker.add_argument("-q", "--quiet", action="store_true")
    p_picker.set_defaults(func=cmd_picker)

    p_apply = sub.add_parser("apply", help="Regenerate files for the current theme")
    p_apply.add_argument("--no-reload", action="store_true")
    p_apply.add_argument("-q", "--quiet", action="store_true")
    p_apply.set_defaults(func=cmd_apply)

    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
